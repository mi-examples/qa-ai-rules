{
  "name": "@metricinsights/qa-ai-rules",
  "version": "1.0.0",
  "description": "Shared QA rules for AI coding tools (Cursor, Claude Code) across MI repositories",
  "license": "MIT",
  "keywords": [
    "qa",
    "testing",
    "cursor",
    "claude",
    "ai",
    "rules",
    "metricinsights"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mi-examples/qa-ai-rules.git"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "qa-ai-rules": "./dist/cli.js"
  },
  "scripts": {
